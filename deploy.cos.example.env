# Copy this file to .env.deploy.local and fill in real values.
# .env.deploy.local is ignored by git.

COS_SECRET_ID=replace-with-your-secret-id
COS_SECRET_KEY=replace-with-your-secret-key

# Example: milk-tea-game-1250000000
COS_BUCKET=your-bucket-name-appid

# Example: ap-shanghai
COS_REGION=ap-shanghai

# Optional. Leave empty when deploying to the COS bucket root.
# Use this if your CDN serves the app from a subdirectory.
COS_PREFIX=
